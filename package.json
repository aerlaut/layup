    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "jsdom": "^28.1.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
